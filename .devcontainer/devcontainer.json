{
  "name": "LiteLLM Proxy",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",

  "mounts": [
    "source=litellm-data,target=/workspace/data/litellm,type=volume"
  ],

  "forwardPorts": [4000],
  "portsAttributes": {
    "4000": {
      "label": "LiteLLM Proxy",
      "onAutoForward": "notify"
    }
  },

  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "nohup bash -c 'while IFS= read -r line; do [[ \"$line\" =~ ^#.*$ ]] && continue; [[ -z \"$line\" ]] && continue; export \"$line\"; done < /workspace/.env; litellm --config /workspace/config/litellm_config.yaml --port 4000' > /workspace/data/litellm/autostart.log 2>&1 &",

  "remoteEnv": {
    "LITELLM_MASTER_KEY": "${localEnv:LITELLM_MASTER_KEY}",
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}",
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "AZURE_API_KEY": "${localEnv:AZURE_API_KEY}",
    "AZURE_API_BASE": "${localEnv:AZURE_API_BASE}",
    "AZURE_API_VERSION": "${localEnv:AZURE_API_VERSION}",
    "GEMINI_API_KEY": "${localEnv:GEMINI_API_KEY}"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "humao.rest-client",
        "42crunch.vscode-openapi"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}